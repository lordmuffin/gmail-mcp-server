# Server
PORT=3000
SERVER_URL=https://your-app.railway.app

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Encryption key for stored refresh tokens (use any random string, 32+ chars)
ENCRYPTION_KEY=generate-a-random-string-at-least-32-characters

# Password to access the /setup page
ADMIN_PASSWORD=pick-a-strong-password

# Data directory for token storage (default: ./data)
# DATA_DIR=./data
